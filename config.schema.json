{
  "pluginAlias": "HikvisionUltimate",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "Hikvision Ultimate \u2014 official Homebridge plugin for Hikvision NVR cameras with ISAPI auto-discovery, motion detection, and FFmpeg streaming.",
  "footerDisplay": "For help and documentation, visit the [GitHub repository](https://github.com/pit5bul/homebridge-hikvision-ultimate).",
  "schema": {
    "type": "object",
    "required": [
      "host",
      "username",
      "password"
    ],
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "Hikvision NVR",
        "description": "Name shown in Homebridge logs."
      },
      "host": {
        "title": "NVR IP / Hostname",
        "type": "string",
        "format": "hostname",
        "placeholder": "192.168.1.100",
        "description": "IP address or hostname of your Hikvision NVR."
      },
      "port": {
        "title": "HTTP Port",
        "type": "integer",
        "default": 80,
        "minimum": 1,
        "maximum": 65535,
        "description": "HTTP port of your NVR. Typically 80 or 8080."
      },
      "secure": {
        "title": "Use HTTPS",
        "type": "boolean",
        "default": false,
        "description": "Enable if your NVR uses HTTPS."
      },
      "username": {
        "title": "Username",
        "type": "string",
        "placeholder": "admin"
      },
      "password": {
        "title": "Password",
        "type": "string"
      },
      "forceDiscovery": {
        "title": "Force Re-discovery",
        "type": "boolean",
        "default": false,
        "description": "Re-discover all cameras on next restart. New cameras are added; existing cameras keep their settings. Resets to false automatically after running."
      },
      "streamType": {
        "title": "Default Stream Type",
        "type": "string",
        "default": "mainstream",
        "oneOf": [
          {
            "title": "Mainstream (high quality)",
            "enum": [
              "mainstream"
            ]
          },
          {
            "title": "Substream (lower bandwidth)",
            "enum": [
              "substream"
            ]
          },
          {
            "title": "Third stream",
            "enum": [
              "thirdstream"
            ]
          }
        ],
        "description": "Default stream type for all cameras. Can be overridden per camera. Substream reduces CPU and bandwidth usage."
      },
      "interfaceName": {
        "title": "Network Interface",
        "type": "string",
        "placeholder": "eth0",
        "description": "Network interface to use for streaming. Leave empty to auto-detect."
      },
      "videoProcessor": {
        "title": "Custom FFmpeg Path",
        "type": "string",
        "placeholder": "/usr/bin/ffmpeg",
        "description": "Path to a custom FFmpeg binary. Required for hardware encoders (VAAPI, NVENC, QuickSync, etc.) \u2014 the bundled FFmpeg does not include hardware support."
      },
      "probeOnStartup": {
        "title": "Probe Streams on Startup",
        "type": "boolean",
        "default": false,
        "description": "Run ffprobe on all cameras at startup to log stream codec info. Useful when setting up or troubleshooting. Adds startup delay."
      },
      "probeTimeout": {
        "title": "Probe Timeout (ms)",
        "type": "integer",
        "default": 10000,
        "minimum": 1000,
        "maximum": 60000,
        "description": "Timeout for ffprobe when probing streams."
      },
      "debugMotion": {
        "title": "Debug Motion Events",
        "type": "boolean",
        "default": false,
        "description": "Log all raw motion events from the NVR event stream. Useful for diagnosing motion detection issues."
      },
      "cameras": {
        "type": "array",
        "items": {
          "title": "Camera",
          "type": "object",
          "required": [
            "channelId",
            "name"
          ],
          "properties": {
            "enabled": {
              "title": "Enabled",
              "type": "boolean",
              "default": true,
              "description": "Disable to exclude this camera from HomeKit without removing it from config."
            },
            "channelId": {
              "title": "Channel ID",
              "type": "integer",
              "minimum": 1,
              "description": "NVR channel number for this camera. Auto-populated by discovery."
            },
            "name": {
              "title": "Camera Name",
              "type": "string",
              "description": "Display name in HomeKit."
            },
            "streamType": {
              "title": "Stream Type Override",
              "type": "string",
              "oneOf": [
                {
                  "title": "Use global default",
                  "enum": [
                    ""
                  ]
                },
                {
                  "title": "Mainstream (high quality)",
                  "enum": [
                    "mainstream"
                  ]
                },
                {
                  "title": "Substream (lower bandwidth)",
                  "enum": [
                    "substream"
                  ]
                },
                {
                  "title": "Third stream",
                  "enum": [
                    "thirdstream"
                  ]
                }
              ],
              "description": "Override the global stream type for this camera only."
            },
            "motion": {
              "title": "Enable Motion Sensor",
              "type": "boolean",
              "default": true,
              "description": "Expose a motion sensor in HomeKit triggered by NVR ISAPI events."
            },
            "motionTimeout": {
              "title": "Motion Timeout (seconds)",
              "type": "integer",
              "default": 1,
              "minimum": 0,
              "description": "Seconds after motion stops before the sensor resets. 0 = never auto-reset."
            },
            "videoConfig": {
              "title": "Video Configuration",
              "type": "object",
              "properties": {
                "qualityPreset": {
                  "title": "Video Quality",
                  "type": "string",
                  "default": "1080p-standard",
                  "oneOf": [
                    {
                      "title": "720p Standard (1280\u00d7720, 1500kbps)",
                      "enum": [
                        "720p-standard"
                      ]
                    },
                    {
                      "title": "1080p Standard (1920\u00d71080, 2000kbps) \u2014 Recommended",
                      "enum": [
                        "1080p-standard"
                      ]
                    },
                    {
                      "title": "1080p High Quality (1920\u00d71080, 4000kbps)",
                      "enum": [
                        "1080p-hq"
                      ]
                    }
                  ],
                  "description": "Video quality preset. HomeKit maximum is 1080p."
                },
                "audio": {
                  "title": "Enable Audio",
                  "type": "boolean",
                  "default": true,
                  "description": "Enable audio streaming from the camera."
                },
                "copyAudio": {
                  "title": "Copy Audio (no transcoding)",
                  "type": "boolean",
                  "default": false,
                  "description": "Pass camera audio directly without re-encoding. Works if your camera outputs AAC. Disable if audio is silent or choppy."
                },
                "vflip": {
                  "title": "Flip Vertically",
                  "type": "boolean",
                  "default": false
                },
                "hflip": {
                  "title": "Flip Horizontally",
                  "type": "boolean",
                  "default": false
                },
                "recording": {
                  "title": "Enable iCloud Recording (HKSV)",
                  "type": "boolean",
                  "default": false,
                  "description": "Record motion events to iCloud via HomeKit Secure Video. Requires an iCloud+ plan and a HomeKit hub (HomePod, Apple TV, or iPad)."
                },
                "unbridge": {
                  "title": "Unbridge Camera",
                  "type": "boolean",
                  "default": false,
                  "description": "Run as a separate accessory instead of through the Homebridge bridge. Recommended when using HKSV for better performance. Requires manual pairing after enabling."
                },
                "prebuffer": {
                  "title": "Enable Pre-recording Buffer",
                  "type": "boolean",
                  "default": false,
                  "description": "Capture a few seconds of video before motion is detected. Requires iCloud Recording to be enabled."
                },
                "prebufferLength": {
                  "title": "Buffer Duration",
                  "type": "integer",
                  "default": 4000,
                  "oneOf": [
                    {
                      "title": "2 seconds",
                      "enum": [
                        2000
                      ]
                    },
                    {
                      "title": "4 seconds (recommended)",
                      "enum": [
                        4000
                      ]
                    },
                    {
                      "title": "6 seconds",
                      "enum": [
                        6000
                      ]
                    },
                    {
                      "title": "8 seconds",
                      "enum": [
                        8000
                      ]
                    }
                  ],
                  "description": "How much video to buffer before a motion event."
                },
                "encoder": {
                  "title": "Video Encoder",
                  "type": "string",
                  "default": "software",
                  "oneOf": [
                    {
                      "title": "Software (libx264) \u2014 works everywhere",
                      "enum": [
                        "software"
                      ]
                    },
                    {
                      "title": "VAAPI \u2014 Intel/AMD GPU on Linux",
                      "enum": [
                        "vaapi"
                      ]
                    },
                    {
                      "title": "NVENC \u2014 NVIDIA GPU",
                      "enum": [
                        "nvenc"
                      ]
                    },
                    {
                      "title": "QuickSync \u2014 Intel integrated GPU",
                      "enum": [
                        "quicksync"
                      ]
                    },
                    {
                      "title": "AMF \u2014 AMD GPU",
                      "enum": [
                        "amf"
                      ]
                    },
                    {
                      "title": "VideoToolbox \u2014 Apple Mac",
                      "enum": [
                        "videotoolbox"
                      ]
                    },
                    {
                      "title": "V4L2 \u2014 Raspberry Pi 4+",
                      "enum": [
                        "v4l2"
                      ]
                    }
                  ],
                  "description": "Hardware encoder reduces CPU usage by 70\u201390%. Requires a custom FFmpeg path with hardware support compiled in."
                },
                "qualityProfile": {
                  "title": "Encoder Quality Profile",
                  "type": "string",
                  "default": "",
                  "oneOf": [
                    {
                      "title": "Use encoder defaults (recommended)",
                      "enum": [
                        ""
                      ]
                    },
                    {
                      "title": "Speed \u2014 fastest encode, lower quality",
                      "enum": [
                        "speed"
                      ]
                    },
                    {
                      "title": "Balanced \u2014 good balance of speed and quality",
                      "enum": [
                        "balanced"
                      ]
                    },
                    {
                      "title": "Quality \u2014 best quality, slower encode",
                      "enum": [
                        "quality"
                      ]
                    }
                  ],
                  "description": "Tune encode speed vs quality for hardware encoders. Has no effect on software encoding."
                },
                "hwaccelDevice": {
                  "title": "Hardware Device Path",
                  "type": "string",
                  "placeholder": "/dev/dri/renderD128",
                  "description": "VAAPI device path. Only change if you have multiple GPUs and the wrong one is being used."
                },
                "maxStreams": {
                  "title": "Max Concurrent Streams",
                  "type": "integer",
                  "default": 2,
                  "minimum": 1,
                  "maximum": 4,
                  "description": "Maximum simultaneous streams for this camera."
                },
                "source": {
                  "title": "Custom RTSP Source",
                  "type": "string",
                  "description": "Override the auto-generated RTSP source. Leave empty to use the NVR-generated URL."
                },
                "stillImageSource": {
                  "title": "Custom Snapshot Source",
                  "type": "string",
                  "description": "Override the auto-generated snapshot source. Leave empty to use the NVR-generated URL."
                },
                "encoderOptions": {
                  "title": "Custom Encoder Options",
                  "type": "string",
                  "placeholder": "Leave empty for automatic",
                  "description": "Manual FFmpeg encoder flags. Overrides quality profile when set. Example: '-preset ultrafast -tune zerolatency'."
                },
                "packetSize": {
                  "title": "RTP Packet Size",
                  "type": "integer",
                  "default": 1316,
                  "minimum": 188,
                  "description": "RTP packet size in bytes. Try 1316, 564, or 376 if video is choppy. Must be a multiple of 188."
                },
                "videoFilter": {
                  "title": "Custom Video Filter",
                  "type": "string",
                  "placeholder": "Leave empty for automatic",
                  "description": "Custom FFmpeg video filter. Leave empty \u2014 the plugin automatically applies the correct filter based on your encoder."
                },
                "debug": {
                  "title": "Debug FFmpeg Output",
                  "type": "boolean",
                  "default": false,
                  "description": "Log full FFmpeg output to Homebridge logs."
                }
              }
            },
            "manufacturer": {
              "title": "Manufacturer",
              "type": "string",
              "placeholder": "Hikvision",
              "description": "Auto-populated from ISAPI. Override if your camera returns incorrect values."
            },
            "model": {
              "title": "Model",
              "type": "string",
              "placeholder": "IP Camera",
              "description": "Auto-populated from ISAPI. Override if your camera returns incorrect values."
            },
            "serialNumber": {
              "title": "Serial Number",
              "type": "string",
              "description": "Auto-populated from ISAPI. Override if your camera returns incorrect values."
            },
            "firmwareRevision": {
              "title": "Firmware Revision",
              "type": "string",
              "description": "Auto-populated from ISAPI. Override if your camera returns incorrect values."
            }
          }
        }
      }
    }
  },
  "layout": [
    {
      "type": "section",
      "title": "\ud83d\udce1 NVR Connection",
      "expandable": true,
      "expanded": true,
      "items": [
        "name",
        "host",
        "port",
        "secure",
        "username",
        "password",
        "forceDiscovery",
        "streamType",
        "interfaceName"
      ]
    },
    {
      "type": "section",
      "title": "\ud83d\udcf7 Cameras",
      "expandable": true,
      "expanded": true,
      "items": [
        {
          "key": "cameras",
          "type": "array",
          "orderable": true,
          "buttonText": "Add Camera",
          "items": [
            {
              "key": "cameras[]",
              "type": "section",
              "title": "Basic",
              "expandable": true,
              "expanded": true,
              "items": [
                "cameras[].enabled",
                "cameras[].name",
                "cameras[].channelId",
                "cameras[].streamType"
              ]
            },
            {
              "key": "cameras[]",
              "type": "section",
              "title": "\ud83c\udfac Video Quality",
              "expandable": true,
              "expanded": false,
              "items": [
                "cameras[].videoConfig.qualityPreset",
                "cameras[].videoConfig.vflip",
                "cameras[].videoConfig.hflip"
              ]
            },
            {
              "key": "cameras[]",
              "type": "section",
              "title": "\ud83d\udd0a Audio",
              "expandable": true,
              "expanded": false,
              "items": [
                "cameras[].videoConfig.audio",
                "cameras[].videoConfig.copyAudio"
              ]
            },
            {
              "key": "cameras[]",
              "type": "section",
              "title": "\ud83c\udfaf Motion Detection",
              "expandable": true,
              "expanded": false,
              "items": [
                "cameras[].motion",
                "cameras[].motionTimeout"
              ]
            },
            {
              "key": "cameras[]",
              "type": "section",
              "title": "\u2601\ufe0f iCloud Recording (HKSV)",
              "expandable": true,
              "expanded": false,
              "items": [
                "cameras[].videoConfig.recording",
                "cameras[].videoConfig.unbridge",
                "cameras[].videoConfig.prebuffer",
                "cameras[].videoConfig.prebufferLength"
              ]
            },
            {
              "key": "cameras[]",
              "type": "section",
              "title": "\ud83d\udd27 FFmpeg / Encoder",
              "expandable": true,
              "expanded": false,
              "items": [
                "cameras[].videoConfig.encoder",
                {
                  "key": "cameras[].videoConfig.qualityProfile",
                  "condition": "model.cameras[arrayIndex].videoConfig.encoder && model.cameras[arrayIndex].videoConfig.encoder !== 'software'"
                },
                "cameras[].videoConfig.hwaccelDevice"
              ]
            },
            {
              "key": "cameras[]",
              "type": "section",
              "title": "\ud83d\udccb Override Camera Info",
              "expandable": true,
              "expanded": false,
              "items": [
                "cameras[].manufacturer",
                "cameras[].model",
                "cameras[].serialNumber",
                "cameras[].firmwareRevision"
              ]
            },
            {
              "key": "cameras[]",
              "type": "section",
              "title": "\ud83d\udc1b Advanced / Debug",
              "expandable": true,
              "expanded": false,
              "items": [
                "cameras[].videoConfig.source",
                "cameras[].videoConfig.stillImageSource",
                "cameras[].videoConfig.encoderOptions",
                "cameras[].videoConfig.videoFilter",
                "cameras[].videoConfig.packetSize",
                "cameras[].videoConfig.maxStreams",
                "cameras[].videoConfig.debug"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "section",
      "title": "\ud83d\udd27 Global FFmpeg",
      "expandable": true,
      "expanded": false,
      "items": [
        "videoProcessor",
        "probeOnStartup",
        "probeTimeout",
        "debugMotion"
      ]
    }
  ]
}